<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lm Bazaar Product Card</title>
</head>
<body>

<div class="product-card">
    <div class="badge">নতুন</div>
    <div class="product-tumb">
        <img src="https://via.placeholder.com/200" alt="Product Image">
    </div>
    <div class="product-details">
        <span class="product-catagory">ফ্যাশন</span>
        <h4><a href="">Lm Bazaar প্রিমিয়াম টি-শার্ট</a></h4>
        <p>উন্নত মানের ফেব্রিক্স দিয়ে তৈরি আরামদায়ক টি-শার্ট।</p>
        <div class="product-bottom-details">
            <div class="product-price"><small>৳১২০০</small>৳৯৫০</div>
            <div class="product-links">
                <a href=""><i class="fa fa-heart"></i></a>
                <a href=""><i class="fa fa-shopping-cart"></i></a>
            </div>
        </div>
    </div>
</div>

</body>
</html>
